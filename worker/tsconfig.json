{
  "extends": "../tsconfig.json",
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2022", "DOM"],
    "allowJs": false,
    "noEmit": true,
    "incremental": false,
    "plugins": []
  },
  "include": ["./**/*.ts"],
  "exclude": ["../node_modules", "./state"]
}
