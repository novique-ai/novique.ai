# Resend API Configuration
# Get your API key from: https://resend.com/api-keys
RESEND_API_KEY=re_your_api_key_here

# Email address where consultation requests will be sent
# This can be updated anytime without code changes
CONSULTATION_EMAIL=your-email@example.com

# Supabase Configuration
# Get these from: https://app.supabase.com/project/_/settings/api
# IMPORTANT: Keep SUPABASE_SERVICE_ROLE_KEY secret - never expose to browser
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Canonical public site URL used to build absolute callback URLs
NEXT_PUBLIC_SITE_URL=

# Anthropic API key for Claude-powered content generation
ANTHROPIC_API_KEY=

# OpenAI API key for AI generation and transcription
OPENAI_API_KEY=

# Deliberate generative social imagery only. Branded cards remain the default.
# Set to 1 to enable the OpenAI gpt-image-1 adapter; disabled for any other value.
GENERATIVE_IMAGE_ENABLED=0

# Brave Search API key for research enrichment
BRAVE_API_KEY=

# Unsplash access key for image search
UNSPLASH_ACCESS_KEY=

# Shared secret required by scheduled cron routes
CRON_SECRET=

# Bearer token required by Jarvis API routes
JARVIS_API_KEY=

# ===========================================
# Social Media API Configuration
# ===========================================

# X (Twitter) API
# Get these from: https://developer.twitter.com/en/portal/dashboard
# Free tier: 500 posts/month
TWITTER_CLIENT_ID=your-twitter-client-id
TWITTER_CLIENT_SECRET=your-twitter-client-secret

# LinkedIn API
# Get these from: https://www.linkedin.com/developers/apps
# Requires Marketing Developer Platform access for company pages
LINKEDIN_CLIENT_ID=your-linkedin-client-id
LINKEDIN_CLIENT_SECRET=your-linkedin-client-secret
# Optional organization author URN (for example, urn:li:organization:123456).
# When set, OAuth requests w_organization_social and publishing uses this author
# only when the connected account's stored token scopes include that permission.
LINKEDIN_ORG_URN=

# Instagram / Meta API
# Get these from: https://developers.facebook.com/apps
# Requires Facebook Business account and Instagram Business/Creator account
META_APP_ID=your-meta-app-id
META_APP_SECRET=your-meta-app-secret

# OAuth callback base; /[platform] is appended automatically
NEXT_PUBLIC_SOCIAL_OAUTH_CALLBACK_URL=http://localhost:3000/api/social/callback

# Generate with: openssl rand -base64 32
SOCIAL_TOKEN_ENCRYPTION_KEY=

# ===========================================
# Twilio Configuration
# ===========================================

# Get these from: https://console.twilio.com
TWILIO_ACCOUNT_SID=your-account-sid
TWILIO_AUTH_TOKEN=your-auth-token
TWILIO_PHONE_NUMBER=+18334560671

# Admin phone number for SMS notifications (voicemail/SMS alerts)
ADMIN_PHONE_NUMBER=+1234567890

# ===========================================
# Discord Webhook Configuration
# ===========================================

# Discord incoming webhook URL for instant notifications
# Create this in Discord: Server Settings > Integrations > Webhooks > Create Webhook
# Copy the webhook URL and paste it here
# Example: https://discord.com/api/webhooks/123456789/abc123def456...
DISCORD_WEBHOOK_URL=

# Discord webhook timeout in milliseconds (default: 10000 = 10 seconds)
# Usually no need to change this unless you have network issues
DISCORD_WEBHOOK_TIMEOUT=10000
